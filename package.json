{
  "name": "medsearch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --host",
    "mobile:url": "powershell -ExecutionPolicy Bypass -File scripts/show-mobile-url.ps1",
    "build": "vite build",
    "build:android": "npm run build && npx cap sync android",
    "android:apk": "npm run build:android && cd android && gradlew.bat assembleDebug",
    "android:open": "npx cap open android",
    "android:sync": "npx cap sync android",
    "android:assets": "npx capacitor-assets generate --android",
    "preview": "vite preview",
    "preview:host": "vite preview --host",
    "share": "powershell -ExecutionPolicy Bypass -File scripts/share-internet.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@tabler/icons-react": "^3.2.0",
    "dexie": "^4.0.4",
    "fuse.js": "^7.0.0",
    "js-sha256": "^0.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.20.0"
  }
}
